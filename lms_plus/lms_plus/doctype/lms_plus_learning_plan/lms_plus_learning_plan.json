{
  "name": "LMS Plus Learning Plan",
  "module": "LMS Plus",
  "doctype": "DocType",
  "is_submittable": 0,
  "track_changes": 1,
  "naming_rule": "By fieldname",
  "autoname": "field:plan_name",
  "fields": [
    {
      "fieldname": "plan_name",
      "fieldtype": "Data",
      "label": "Plan Name",
      "reqd": 1,
      "unique": 1
    },
    {
      "fieldname": "description",
      "fieldtype": "Small Text",
      "label": "Description"
    },
    {
      "fieldname": "is_active",
      "fieldtype": "Check",
      "label": "Active",
      "default": "1"
    },
    {
      "fieldname": "courses_section",
      "fieldtype": "Section Break",
      "label": "Courses (Ordered)"
    },
    {
      "fieldname": "courses",
      "fieldtype": "Table",
      "label": "Courses",
      "options": "LMS Plus Learning Plan Course"
    }
  ],
  "permissions": [
    { "role": "LMS Manager", "read": 1, "write": 1, "create": 1, "delete": 1 }
  ]
}
