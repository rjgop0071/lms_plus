{
  "name": "LMS Plus FAQ",
  "module": "LMS Plus",
  "doctype": "DocType",
  "track_changes": 1,
  "naming_rule": "Expression",
  "autoname": "FAQ-.#####",
  "fields": [
    {
      "fieldname": "question",
      "fieldtype": "Data",
      "label": "Question",
      "reqd": 1,
      "in_list_view": 1
    },
    {
      "fieldname": "answer",
      "fieldtype": "Text Editor",
      "label": "Answer",
      "reqd": 1
    },
    {
      "fieldname": "category",
      "fieldtype": "Select",
      "label": "Category",
      "options": "General\nCourses\nEnrollment\nTechnical\nCertificates",
      "in_list_view": 1
    },
    {
      "fieldname": "order",
      "fieldtype": "Int",
      "label": "Display Order",
      "default": "0"
    },
    {
      "fieldname": "published",
      "fieldtype": "Check",
      "label": "Published",
      "default": "1",
      "in_list_view": 1
    }
  ],
  "permissions": [
    { "role": "LMS Manager", "read": 1, "write": 1, "create": 1, "delete": 1 },
    { "role": "All", "read": 1, "if_owner": 0 }
  ]
}
